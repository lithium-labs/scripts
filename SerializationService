-- HELPER FUNCTIONS
local function logError(context: string, details: string, help: string?)
	local msg = string.format(
		"\n[SerializationService Error]\n  Context: %s\n  Details: %s",
		context, details
	)
	if help then
		msg = msg .. string.format("\n  Help:    %s", help)
	end
	warn(msg .. "\n")
end

local function getSorted(tbl, f)
	local clone = table.clone(tbl)
	table.sort(clone, f)
	return clone
end

local function getKeys(dict)
	local keys = {}
	for k in dict do table.insert(keys, k) end
	return keys
end

-- DEFINITIONS
local numberIdentifiers = getSorted({"nan", "+inf", "-inf", "u8", "u16", "u32", "u64", "i8", "i16", "i32", "i64", "f32", "f64"})
local datatypeList = getSorted({"number", "true", "false", "string", "Color3", "Vector2", "Vector3", "UDim2", "CFrame", "EnumItem", "Instance", "Font", "PhysicalProperties", "NumberSequence", "ColorSequence", "nil"})

local enumIndexMap = {}
for i, enum in ipairs(enumList) do enumIndexMap[enum] = i end

local sortedInstances = getSorted(getKeys(instanceTable))
local sortedKeys = {}
local propertyIndices = {}

for k, v in instanceTable do
	local keys = getSorted(getKeys(v))
	sortedKeys[k] = keys
	local flipped = {}
	for i, propName in ipairs(keys) do flipped[propName] = i end
	propertyIndices[k] = flipped
end

-- NUMBER LOGIC
local function classifyNumber(n: number)
	local function findIdentifier(t) return string.char(table.find(numberIdentifiers, t)) end
	if n ~= n then return findIdentifier("nan")
	elseif n == math.huge then return findIdentifier("+inf")
	elseif n == -math.huge then return findIdentifier("-inf")
	end
	if n % 1 == 0 then
		if n >= 0 then
			if n <= 0xFF then return findIdentifier("u8")
			elseif n <= 0xFFFF then return findIdentifier("u16")
			elseif n <= 0xFFFFFFFF then return findIdentifier("u32")
			else return findIdentifier("u64") end
		else
			if n >= -0x80 then return findIdentifier("i8")
			elseif n >= -0x8000 then return findIdentifier("i16")
			elseif n >= -0x80000000 then return findIdentifier("i32")
			else return findIdentifier("i64") end
		end
	else
		return (string.unpack("f", string.pack("f", n)) == n) and findIdentifier("f32") or findIdentifier("f64")
	end
end

local function packNumber(n, t_index)
	local t = numberIdentifiers[t_index]
	if t == "u8" then return string.pack("<B", n)
	elseif t == "u16" then return string.pack("<I2", n)
	elseif t == "u32" then return string.pack("<I4", n)
	elseif t == "u64" then return string.pack("<I8", n)
	elseif t == "i8" then return string.pack("<b", n)
	elseif t == "i16" then return string.pack("<i2", n)
	elseif t == "i32" then return string.pack("<i4", n)
	elseif t == "i64" then return string.pack("<i8", n)
	elseif t == "f32" then return string.pack("<f", n)
	else return string.pack("<d", n) end
end

-- DATATYPE SERIALIZATION
local function serializeDatatype(datatype: any, instanceMap: {[Instance]: number}?)
	local function getIdentifier(t) return string.char(table.find(datatypeList, t)) end
	local t = typeof(datatype)

	-- Handle boolean as true or false cuz it saves space
	if t == "boolean" then
		return getIdentifier(tostring(datatype))
	end

	local idIdx = table.find(datatypeList, t)
	if not idIdx then
		warn("Unhandled type:", t)
		return getIdentifier("nil")
	end
	local identifier = string.char(idIdx)

	if t == "nil" then return identifier
	elseif t == "number" then
		local numId = classifyNumber(datatype)
		return identifier .. numId .. packNumber(datatype, string.byte(numId))
	elseif t == "string" then
		return identifier .. string.pack("<I2", #datatype) .. datatype
	elseif t == "Color3" then
		return identifier .. string.pack("BBB", math.floor(datatype.R*255), math.floor(datatype.G*255), math.floor(datatype.B*255))
	elseif t == "Vector3" then
		return identifier .. string.pack("<fff", datatype.X, datatype.Y, datatype.Z)
	elseif t == "Vector2" then
		return identifier .. string.pack("<ff", datatype.X, datatype.Y)
	elseif t == "UDim2" then
		return identifier .. string.pack("<fi4fi4", datatype.X.Scale, datatype.X.Offset, datatype.Y.Scale, datatype.Y.Offset)
	elseif t == "CFrame" then
		return identifier .. string.pack("<ffffffffffff", datatype:GetComponents())
	elseif t == "EnumItem" then
		local enumId = enumIndexMap[datatype.EnumType]
		return identifier .. string.pack("<I2i4", enumId or 0, datatype.Value)
	elseif t == "Font" then
		return identifier .. string.pack("<I2", #datatype.Family) .. datatype.Family .. string.pack("<I2I2", datatype.Weight.Value, datatype.Style.Value)
	elseif t == "PhysicalProperties" then
		return identifier .. string.pack("<fffff", datatype.Density, datatype.Friction, datatype.Elasticity, datatype.FrictionWeight, datatype.ElasticityWeight)
	elseif t == "NumberSequence" then
		local keypoints = datatype.Keypoints
		local res = identifier .. string.pack("<I2", #keypoints)
		for _, kp in ipairs(keypoints) do
			res = res .. string.pack("<fff", kp.Time, kp.Value, kp.Envelope)
		end
		return res
	elseif t == "ColorSequence" then
		local keypoints = datatype.Keypoints
		local res = identifier .. string.pack("<I2", #keypoints)
		for _, kp in ipairs(keypoints) do
			res = res .. string.pack("<fBBB", kp.Time, math.floor(kp.Value.R*255), math.floor(kp.Value.G*255), math.floor(kp.Value.B*255))
		end
		return res
	elseif t == "Instance" then
		if instanceMap and instanceMap[datatype] then
			return identifier .. string.pack("<I4", instanceMap[datatype])
		else
			return getIdentifier("nil")
		end
	end
	return getIdentifier("nil")
end

-- INSTANCE SERIALIZATION
local function serializeProperties(target: Instance, instanceMap: {[Instance]: number}?)
	local class = target.ClassName
	local classId = table.find(sortedInstances, class)
	if not classId or not instanceTable[class] then return "" end

	local data = string.char(classId)
	for i, propName in ipairs(sortedKeys[class]) do
		local success, val = pcall(function() return target[propName] end)
		local default = instanceTable[class][propName]
		if default == NIL then default = nil end

		if success and val ~= default then
			local serializedVal = serializeDatatype(val, instanceMap)
			if serializedVal then
				-- PropID .. DataLength .. Data
				data = data .. string.char(i) .. string.pack("<I2", #serializedVal) .. serializedVal
			end
		end
	end
	return data .. string.char(0)
end

local function buildInstanceMap(target: Instance, map: {[Instance]: number}, list: {Instance})
	table.insert(list, target)
	map[target] = #list
	for _, child in target:GetChildren() do
		if instanceTable[child.ClassName] then
			buildInstanceMap(child, map, list)
		end
	end
end

local function serialize(target: Instance)
	if not instanceTable[target.ClassName] then return "" end

	local map = {}
	local list = {}
	buildInstanceMap(target, map, list)

	local function _serialize(inst: Instance)
		local instanceData = serializeProperties(inst, map)
		if #instanceData == 0 then return "" end

		local validChildren = {}
		for _, child in inst:GetChildren() do
			if instanceTable[child.ClassName] then
				table.insert(validChildren, child)
			end
		end

		instanceData = instanceData .. string.pack("<I2", #validChildren)
		for _, child in validChildren do
			instanceData = instanceData .. _serialize(child)
		end
		return instanceData
	end

	return _serialize(target)
end

-- DESERIALIZATION
local function deserializeDatatype(data: string, offset: number)
	local typeId = string.byte(data, offset)
	local typeName = datatypeList[typeId]
	offset += 1

	if typeName == "nil" then return nil, offset
	elseif typeName == "true" then return true, offset
	elseif typeName == "false" then return false, offset
	elseif typeName == "string" then
		local len = string.unpack("<I2", data, offset)
		return string.sub(data, offset + 2, offset + 1 + len), offset + 2 + len
	elseif typeName == "number" then
		local nIdx = string.byte(data, offset)
		local nType = numberIdentifiers[nIdx]
		local formatMap = {u8="B", u16="I2", u32="I4", u64="I8", i8="b", i16="i2", i32="i4", i64="i8", f32="f", f64="d", nan="d", ["+inf"]="d", ["-inf"]="d"}
		local sizeMap = {B=1, I2=2, I4=4, I8=8, b=1, i2=2, i4=4, i8=8, f=4, d=8}
		local fmt = formatMap[nType]
		local val = string.unpack("<" .. fmt, data, offset + 1)
		return val, offset + 1 + sizeMap[fmt]
	elseif typeName == "Color3" then
		local r, g, b = string.unpack("BBB", data, offset)
		return Color3.fromRGB(r, g, b), offset + 3
	elseif typeName == "Vector3" then
		local x, y, z = string.unpack("<fff", data, offset)
		return Vector3.new(x, y, z), offset + 12
	elseif typeName == "Vector2" then
		local x, y = string.unpack("<ff", data, offset)
		return Vector2.new(x, y), offset + 8
	elseif typeName == "UDim2" then
		local xs, xo, ys, yo = string.unpack("<fi4fi4", data, offset)
		return UDim2.new(xs, xo, ys, yo), offset + 16
	elseif typeName == "CFrame" then
		local c = {string.unpack("<ffffffffffff", data, offset)}
		return CFrame.new(unpack(c, 1, 12)), offset + 48
	elseif typeName == "EnumItem" then
		local eId, eVal = string.unpack("<I2i4", data, offset)
		local enum = enumList[eId]
		if enum then
			for _, item in ipairs(enum:GetEnumItems()) do
				if item.Value == eVal then return item, offset + 6 end
			end
		end
		return nil, offset + 6
	elseif typeName == "Font" then
		local len = string.unpack("<I2", data, offset)
		local family = string.sub(data, offset + 2, offset + 1 + len)
		local weightVal, styleVal = string.unpack("<I2I2", data, offset + 2 + len)

		local weightEnum, styleEnum = Enum.FontWeight.Regular, Enum.FontStyle.Normal
		for _, w in Enum.FontWeight:GetEnumItems() do
			if w.Value == weightVal then weightEnum = w; break end
		end
		for _, s in Enum.FontStyle:GetEnumItems() do
			if s.Value == styleVal then styleEnum = s; break end
		end

		return Font.new(family, weightEnum, styleEnum), offset + 6 + len
	elseif typeName == "PhysicalProperties" then
		local den, fri, ela, friW, elaW = string.unpack("<fffff", data, offset)
		return PhysicalProperties.new(den, fri, ela, friW, elaW), offset + 20
	elseif typeName == "NumberSequence" then
		local count = string.unpack("<I2", data, offset)
		offset += 2
		local keypoints = table.create(count)
		for i = 1, count do
			local time, val, env = string.unpack("<fff", data, offset)
			keypoints[i] = NumberSequenceKeypoint.new(time, val, env)
			offset += 12
		end
		return NumberSequence.new(keypoints), offset
	elseif typeName == "ColorSequence" then
		local count = string.unpack("<I2", data, offset)
		offset += 2
		local keypoints = table.create(count)
		for i = 1, count do
			local time, r, g, b = string.unpack("<fBBB", data, offset)
			keypoints[i] = ColorSequenceKeypoint.new(time, Color3.fromRGB(r, g, b))
			offset += 7
		end
		return ColorSequence.new(keypoints), offset
	elseif typeName == "Instance" then
		local index = string.unpack("<I4", data, offset)
		return {__isInstancePtr = true, index = index}, offset + 4
	end
	return nil, offset
end

local function deserialize(data: string, offset: number)
	local instList = {}
	local deferredProps = {}

	local function _deserialize(currentOffset)
		local classId = string.byte(data, currentOffset)
		local className = sortedInstances[classId]
		if not className then return nil, currentOffset + 1 end
		currentOffset += 1

		local propKeys = sortedKeys[className]

		local props = {}
		local localDeferred = {}

		-- Properties
		while true do
			local propId = string.byte(data, currentOffset)
			currentOffset += 1
			if propId == 0 then break end

			local len = string.unpack("<I2", data, currentOffset)
			local val, _ = deserializeDatatype(data, currentOffset + 2)
			local propName = propKeys[propId]
			if propName then
				if type(val) == "table" and val.__isInstancePtr then
					table.insert(localDeferred, {prop = propName, ptr = val.index})
				else
					props[propName] = val
				end
			end
			currentOffset += 2 + len
		end

		local inst
		if className == "MeshPart" and props.MeshId and props.MeshId ~= "" then
			local mId = props.MeshId
			local col = props.CollisionFidelity or Enum.CollisionFidelity.Box
			local ren = props.RenderFidelity or Enum.RenderFidelity.Automatic

			local success, result = pcall(function()
				local AssetService = game:GetService("AssetService")
				if AssetService and pcall(function() return AssetService.CreateMeshPartAsync end) then
					-- Extract the number from "rbxassetid://123" or similar
					local numId = string.match(tostring(mId), "%d+")
					if numId then
						local content = Content.fromAssetId(tonumber(numId))
						return AssetService:CreateMeshPartAsync(content, {
							CollisionFidelity = col,
							RenderFidelity = ren
						})
					end
				end
				-- Fallback for InsertService or if string extraction fails
				return game:GetService("InsertService"):CreateMeshPartAsync(tostring(mId), col, ren)
			end)

			if success and typeof(result) == "Instance" then
				inst = result
			else
				inst = Instance.new(className)
				logError(
					"Deserializing MeshPart",
					string.format("Failed to create MeshPart asynchronously with MeshId %q. Internal error: %s", mId, tostring(result)),
					"MeshId is read-only and requires AssetService/InsertService to construct. Ensure your script context has permissions and the asset ID is valid."
				)
			end
		else
			inst = Instance.new(className)
		end

		table.insert(instList, inst)

		for k, v in props do
			if className ~= "MeshPart" and k ~= "MeshId" then
				local s, err = pcall(function() inst[k] = v end)
				if not s then
					logError(
						string.format("Applying property %q to %s", k, className),
						tostring(err),
						string.format("The property might be read-only, restricted in your current identity level, or the value '%s' is invalid.", tostring(v))
					)
				end
			end
		end

		for _, def in localDeferred do
			table.insert(deferredProps, {inst = inst, prop = def.prop, ptr = def.ptr})
		end

		-- Children
		local childCount = string.unpack("<I2", data, currentOffset)
		currentOffset += 2
		for i = 1, childCount do
			local child, nextOff = _deserialize(currentOffset)
			if child then child.Parent = inst end
			currentOffset = nextOff
		end

		return inst, currentOffset
	end

	local rootInst, finalOffset = _deserialize(offset or 1)

	for _, def in deferredProps do
		local targetInst = instList[def.ptr]
		if targetInst then
			pcall(function() def.inst[def.prop] = targetInst end)
		end
	end

	return rootInst, finalOffset
end

return {
	serialize = serialize,
	deserialize = function(data, offset) return deserialize(data, offset or 1) end
}
